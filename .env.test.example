# Copia in .env.test.local per override locali (opzionale).
# Il provisioning usa .env.local per Supabase service role.

PLAYWRIGHT_PORT=3099
PLAYWRIGHT_BASE_URL=http://localhost:3099

# Produzione: npm run test:e2e:prod
# A fine run, global-teardown rende private le campagne E2E-QA automaticamente.
# Manuale: PLAYWRIGHT_BASE_URL=https://barberanddragons.com npm run e2e:teardown
# Forza teardown anche in locale: E2E_TEARDOWN_PRIVATE=1 npm run e2e:teardown

# Admin esistente (default: testolone@gmail.com)
E2E_ADMIN_EMAIL=testolone@gmail.com
E2E_ADMIN_PASSWORD=

# Account creati automaticamente da npm run e2e:provision
E2E_GM_EMAIL=e2e-gm@barberandragons.qa
E2E_PLAYER_EMAIL=e2e-player@barberandragons.qa
E2E_PASSWORD=E2eBd2026!

# Campagne seed per test futuri
E2E_CAMPAIGN_TORNEO_ID=0d696961-fe0a-4b66-9f1a-856821396c29
